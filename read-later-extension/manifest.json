{
  "manifest_version": 3,
  "name": "Octoman Read Later",
  "version": "1.0",
  "description": "One-click save any page to read later. Organize your reading list, edit notes, restore from trash. / 一键保存页面稍后阅读。整理清单、编辑备注、回收站恢复。",
  "permissions": [
    "storage",
    "tabs",
    "sidePanel"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Read Later",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
