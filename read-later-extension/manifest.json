{
  "manifest_version": 3,
  "name": "Octoman Read Later",
  "version": "1.0",
  "description": "Octoman Read Later - 保存当前页面到待办列表，支持管理、编辑和删除",
  "permissions": [
    "storage",
    "tabs",
    "sidePanel"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Read Later",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
